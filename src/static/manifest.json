{
  "manifest_version": 2,
  "version": "0.4.0",
  "name": "Web Exporter",
  "description": "__MSG_extensionDescription__",
  "author": "eight",
  "homepage_url": "https://github.com/eight04/web-exporter",
  "browser_specific_settings": {
    "gecko": {
      "id": "web-exporter@eight04.blogspot.com",
      "strict_min_version": "141.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'",
  "permissions": [
    "<all_urls>",
    "storage",
    "unlimitedStorage",
    "notifications",
    "webRequest",
    "webRequestBlocking",
    "webRequestFilterResponse",
    "webRequestFilterResponse.serviceWorkerScript",
    "webNavigation",
    "tabs",
    "downloads",
    "cookies",
    "scripting"
  ],
  "browser_action": {
    "default_title": "Web Exporter",
    "default_icon": "images/icon.svg"
  },
  "background": {
    "scripts": []
  },
  "sidebar_action": {
    "default_panel": "sidebar.html",
    "default_title": "Web Exporter",
    "default_icon": "images/icon.svg"
  },
  "icons": {
    "32": "images/icon.svg"
  },
  "default_locale": "en",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
