{
  "name": "web-exporter",
  "version": "0.4.0",
  "description": "A webextension to export data, media from websites.",
  "author": "eight04 <eight04@gmail.com>",
  "license": "MIT",
  "scripts": {
    "lint": "eslint . --cache && stylelint 'src/**/*.{css,scss}'",
    "test": "npm run lint && npm run build-src && web-ext lint",
    "start": "web-ext run",
    "build": "run-s build-version build-index build-src build-artifact",
    "build-debug": "cross-env NODE_ENV=development npm run build",
    "build-index": "node tools/site-index.mjs",
    "build-src": "shx rm -rf build/* && rollup -c",
    "build-version": "sync-version src/static/manifest.json",
    "build-watch": "rollup -cw",
    "build-artifact": "shx rm -rf web-ext-artifacts/* && web-ext build --ignore-files **/*.map && (git archive -o web-ext-artifacts/source.zip HEAD || exit 0)",
    "dev": "run-p -r build-watch start",
    "preversion": "npm test",
    "version": "npm run build-version && git add .",
    "postversion": "git push --follow-tags && npm run build",
    "changelog": "node tools/changelog.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-yaml": "^4.1.2",
    "@web/rollup-plugin-copy": "^0.5.1",
    "browserslist": "^4.28.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "npm-run-all": "^4.1.5",
    "path-unified": "^0.2.0",
    "rollup": "^4.60.1",
    "rollup-plugin-cjs-es": "^3.0.0",
    "rollup-plugin-iife": "^0.8.0",
    "rollup-plugin-svelte": "^7.2.3",
    "rollup-plugin-write-output": "^0.2.1",
    "shx": "^0.4.0",
    "stylelint": "^17.6.0",
    "stylelint-browser-compat": "^1.0.0-beta.180",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.55.1",
    "sync-version": "^1.1.0",
    "tiny-glob": "^0.2.9",
    "web-ext": "^10.1.0",
    "webext-menus": "^0.3.2",
    "webext-pref": "^0.6.0",
    "webext-pref-ui": "^0.2.1",
    "webextension-polyfill": "^0.12.0"
  },
  "repository": "eight04/web-exporter",
  "private": true,
  "dependencies": {
    "delay": "^7.0.0",
    "dexie": "^4.4.2",
    "event-lite": "^1.0.0",
    "js-pyformat": "^0.0.2",
    "js-yaml": "^4.1.1",
    "linkify-plus-plus-core": "^0.8.2",
    "p-event": "^7.1.0",
    "urlpattern-polyfill": "^10.1.0"
  }
}
